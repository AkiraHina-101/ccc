# regen_paths.tcl — Rewrite nastran_control.mac with absolute paths
# to the current folder. Run after copying the folder to a new machine:
#     tclsh regen_paths.tcl
# HyperMesh is not required. Use tclsh or the HM console.

set here [file normalize [file dirname [info script]]]
set here [string map {\\ /} $here]

set mac "// Nastran Control Tool — standalone User page buttons.
// Generated by regen_paths.tcl on this machine.
// Load in the HM Tcl console:
//   *includemacrofile(\"$here/nastran_control.mac\")

*createtext(1, \"-- Nastran Control --\", 0, 0)
*createbutton(1, \"NC Launch\", 1, 0, 10, GREEN, \"Open Nastran Control tool (scan + table)\", \"EvalTcl\", \"$here/nastran_control.tcl\")
*createbutton(1, \"NC Save\",   2, 0, 10, CYAN,  \"Save current Nastran Control session state to CSV\", \"EvalTcl\", \"$here/nc_save.tcl\")

*beginmacro(\"EvalTcl\")
*evaltclscript(\$1,0)
*endmacro()

*setactivepage(1)
"

set out [file join $here nastran_control.mac]
set fp [open $out w]
puts -nonewline $fp $mac
close $fp
puts "Wrote $out"
puts "Paths point at: $here"
